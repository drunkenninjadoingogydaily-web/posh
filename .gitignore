# ═══════════════════════════════════════════════════════
#  POSH — .gitignore
# ═══════════════════════════════════════════════════════

# Environment variables — NEVER commit these!
.env
.env.local
.env.production

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Node (if added later)
node_modules/

# Build artifacts
dist/
build/
